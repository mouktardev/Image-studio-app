{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Studio",
  "version": "0.1.0",
  "identifier": "com.imagestudio.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Image Studio",
        "width": 943,
        "height": 688,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "img-src": "'self' asset: http://asset.localhost blob: data:"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVEOEY4MjZFNzY4NzBEODIKUldTQ0RZZDJib0tQWFJSMU1NUlBkQ1ljUmZieXNLNzFuMzM2N0RMZjNrWWRPWWpRMDlzaWZURGEK",
      "endpoints": [
        "https://github.com/mouktardev/Image-studio-app/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
